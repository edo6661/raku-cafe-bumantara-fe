                </BarChart>
              </ResponsiveContainer>
            ) : (
              <div className="flex flex-col items-center justify-center h-full text-slate-400">
                <Wallet size={32} className="mb-2 text-slate-300" />
                <p className="text-sm font-medium">Belum ada transaksi</p>
              </div>
